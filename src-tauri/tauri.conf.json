{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "workbench",
  "version": "0.1.0",
  "identifier": "se.nena.workbench",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Workbench",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUyRDJFNTBGNkM1NzE2QjQKUldTMEZsZHNEK1hTVWttRWY0MTRlRWVWai9DSy93dFQ2dFU5ZnBPTjA3bXBLeW1NR0Ewd3JhL0wK",
      "endpoints": [
        "https://github.com/apstrand/workbench/releases/latest/download/latest.json"
      ]
    }
  }
}
